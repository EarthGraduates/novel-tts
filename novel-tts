#!/home/phoenix/miniconda3/envs/qwen3-tts/bin/python
"""novel-tts — 小说转有声读物工具 (Qwen3-TTS)."""

import sys
import os

# ── ROCm performance defaults (must be set before any torch import) ──────
os.environ.setdefault("MIOPEN_FIND_MODE", "2")
os.environ.setdefault("TORCH_BLAS_PREFER_HIPBLASLT", "0")

# Ensure we can import tts_core from project root
PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
if PROJECT_ROOT not in sys.path:
    sys.path.insert(0, PROJECT_ROOT)

MENU = [
    ("init",     "项目初始化 — 新建小说项目，选音色"),
    ("parse",    "解析小说 TXT → JSON 结构化"),
    ("manifest", "编辑章节清单（合并/拆分/跳过）"),
    ("view",     "查看/编辑章节内容，标记拆分点"),
    ("apply",    "应用 manifest 修改到 novel.json"),
    ("generate", "开始音频生成（支持断点续传）"),
    ("status",   "查看生成进度"),
]


def run_cmd(cmd, args=None):
    """Execute a single command. Returns True on success."""
    if args is None:
        args = []
    try:
        if cmd == "init":
            from tts_core.commands.init_cmd import run
            run(args)
        elif cmd == "parse":
            from tts_core.commands.parse_cmd import run
            run(args)
        elif cmd == "manifest":
            from tts_core.commands.manifest_cmd import run
            run(args)
        elif cmd == "view":
            from tts_core.commands.view_cmd import run
            run(args)
        elif cmd == "apply":
            from tts_core.commands.apply_cmd import run
            run(args)
        elif cmd == "generate":
            from tts_core.commands.generate_cmd import run
            run(args)
        elif cmd == "status":
            from tts_core.commands.status_cmd import run
            run(args)
        else:
            print(f"未知命令: {cmd}")
            return False
        return True
    except SystemExit:
        return True  # commands call sys.exit(0), treat as success
    except KeyboardInterrupt:
        print("\n⏹ 已取消")
        return True


def menu():
    """Interactive menu loop."""
    while True:
        print()
        print("╔══════════════════════════════════════╗")
        print("║   📖 novel-tts — 有声读物工具        ║")
        print("║      引擎: Qwen3-TTS 0.6B            ║")
        print("╚══════════════════════════════════════╝")
        print()
        print("  工作流: init → parse → manifest → apply → generate")
        print()
        for i, (name, desc) in enumerate(MENU, 1):
            print(f"  [{i}] {name:<10s} {desc}")
        print(f"  [0] exit       退出")
        print()

        try:
            choice = input("  选哪个？[0]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not choice or choice == "0":
            print("  再见！")
            break

        try:
            idx = int(choice) - 1
            if 0 <= idx < len(MENU):
                cmd, desc = MENU[idx]
                print(f"\n▶ {desc}")
                run_cmd(cmd)
                # Pause before returning to menu
                if cmd not in ("init", "view"):  # these are short interactions
                    try:
                        input("\n  按 Enter 返回菜单...")
                    except (EOFError, KeyboardInterrupt):
                        print()
            else:
                print(f"  请输入 0-{len(MENU)}")
        except ValueError:
            print(f"  请输入数字")


def main():
    if len(sys.argv) < 2:
        menu()
    else:
        # Direct mode: ./novel-tts <cmd> [args...]
        run_cmd(sys.argv[1], sys.argv[2:])


if __name__ == "__main__":
    main()
