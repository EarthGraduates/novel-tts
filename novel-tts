#!/home/phoenix/miniconda3/envs/qwen3-tts/bin/python
"""novel-tts — 小说转有声读物工具 (Qwen3-TTS)."""

import sys
import os

# ── ROCm performance defaults (must be set before any torch import) ──────
os.environ.setdefault("MIOPEN_FIND_MODE", "2")
os.environ.setdefault("TORCH_BLAS_PREFER_HIPBLASLT", "0")
os.environ.setdefault("TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL", "1")
os.environ.setdefault("FLASH_ATTENTION_TRITON_AMD_AUTOTUNE", "TRUE")

# Ensure we can import tts_core from project root
PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
if PROJECT_ROOT not in sys.path:
    sys.path.insert(0, PROJECT_ROOT)

MENU = [
    ("init",     "项目初始化 — 新建小说项目，选音色"),
    ("parse",    "解析小说 TXT → JSON 结构化"),
    ("manifest", "编辑章节清单（合并/拆分/跳过）"),
    ("view",     "查看/编辑章节内容，标记拆分点"),
    ("apply",    "应用 manifest 修改到 novel.json"),
    ("generate", "开始音频生成（支持断点续传）"),
    ("status",   "查看生成进度"),
]

# After each command, suggest the next logical step (Enter = proceed)
NEXT_STEP = {
    "init":     "parse",
    "parse":    "manifest",
    "manifest": "apply",
    "apply":    "generate",
}

# Commands that need user input before running
# Each entry: (prompt, default, description)
CMD_ARGS = {
    "view":     ("章节ID（如 0003）", None, "输入要查看的章节编号"),
    "generate": ("章节ID 或 X=全部", "X", "0001=生成第一章，X=生成全部章节"),
}


def run_cmd(cmd, args=None):
    """Execute a single command. Returns True on success, False on error."""
    if args is None:
        args = []
    try:
        if cmd == "init":
            from tts_core.commands.init_cmd import run
            run(args)
        elif cmd == "parse":
            from tts_core.commands.parse_cmd import run
            run(args)
        elif cmd == "manifest":
            from tts_core.commands.manifest_cmd import run
            run(args)
        elif cmd == "view":
            from tts_core.commands.view_cmd import run
            run(args)
        elif cmd == "apply":
            from tts_core.commands.apply_cmd import run
            run(args)
        elif cmd == "generate":
            from tts_core.commands.generate_cmd import run
            run(args)
        elif cmd == "status":
            from tts_core.commands.status_cmd import run
            run(args)
        else:
            print(f"未知命令: {cmd}")
            return False
    except SystemExit as e:
        # sys.exit(0) = success, sys.exit(1) = error
        return e.code == 0 or e.code is None
    except KeyboardInterrupt:
        print("\n⏹ 已取消")
        return True
    except Exception as e:
        print(f"\n❌ 错误: {e}")
        return False
    return True


def menu():
    """Interactive menu loop with workflow guidance."""
    while True:
        print()
        print("╔══════════════════════════════════════╗")
        print("║   📖 novel-tts — 有声读物工具        ║")
        print("║      引擎: Qwen3-TTS 0.6B            ║")
        print("╚══════════════════════════════════════╝")
        print()
        print("  工作流: init → parse → manifest → apply → generate")
        print()
        for i, (name, desc) in enumerate(MENU, 1):
            print(f"  [{i}] {name:<10s} {desc}")
        print(f"  [0] exit       退出")
        print()

        try:
            choice = input("  选哪个？[0]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not choice or choice == "0":
            print("  再见！")
            break

        try:
            idx = int(choice) - 1
            if 0 <= idx < len(MENU):
                cmd, desc = MENU[idx]
                _run_with_next(cmd, desc)
            else:
                print(f"  请输入 0-{len(MENU)}")
        except ValueError:
            print(f"  请输入数字")


def _run_with_next(cmd, desc):
    """Execute a command, then offer to jump to the next workflow step."""
    print(f"\n▶ {desc}")

    # Prompt for arguments if the command needs them
    args = []
    if cmd in CMD_ARGS:
        prompt, default, hint = CMD_ARGS[cmd]
        if hint:
            print(f"   {hint}")
        if default:
            prompt = f"   {prompt} [默认 {default}]"
        else:
            prompt = f"   {prompt}"
        try:
            val = input(f"{prompt}: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if not val:
            val = default if default else ""
        if val:
            args = [val]

    success = run_cmd(cmd, args)

    if not success:
        input("\n  按 Enter 返回菜单...")
        return

    next_cmd = NEXT_STEP.get(cmd)
    if next_cmd:
        # Find the next command's description
        next_desc = next((d for n, d in MENU if n == next_cmd), next_cmd)
        print(f"\n  下一步: {next_cmd} — {next_desc}")
        try:
            choice = input(f"  按 Enter 继续，或输入其他内容返回菜单: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if not choice:
            _run_with_next(next_cmd, next_desc)
    else:
        input("\n  按 Enter 返回菜单...")


def main():
    if len(sys.argv) < 2:
        menu()
    else:
        # Direct mode: ./novel-tts <cmd> [args...]
        run_cmd(sys.argv[1], sys.argv[2:])


if __name__ == "__main__":
    main()
